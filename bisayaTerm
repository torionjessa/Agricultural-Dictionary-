/*
Group 2: Agriculture Bisaya Dictionary
Purpose: This program allows the user to search Bisaya agriculture terms 
         and display their definitions using a 1D array.
*/

import java.util.Scanner;

public class AgriBisayaDicionary {

    
    // MEMBER 1: Radjeline Gambong
    // This code declares the 1D array that stores all Bisaya agriculture terms.
    
    
    private String[] agriDictionary = new String[50]
      // This code declares the counter variable to track the number of entries.
       int count = 30;
       
        // This code loads the first set of agriculture terms into the array.


    public void agriTerm1 () {
agriDictionary[0] = "Humay: Tanum nga ginagamit para sa bugas";
        agriDictionary[1] = "Mais: Tanum nga ginagamit para sa pagkaon";
        agriDictionary[2] = "Baboy: Hayop nga ginabuhat para sa karne";
        agriDictionary[3] = "Kanding: Hayop nga ginabuhat para sa gatas ug karne";
        agriDictionary[4] = "Manok: Hayop nga ginabuhat para sa itlog ug karne";
        agriDictionary[5] = "Saging: Tanum nga nagahatag og bunga nga saging";
        agriDictionary[6] = "Mangga: Tanum nga nagahatag og bunga nga mangga";
        agriDictionary[7] = "Niyog: Tanum nga nagahatag og lubi ug lana";
        agriDictionary[8] = "Palay: Humay nga wala pa gyud hinimo og bugas";
        agriDictionary[9] = "Isda: Hayop nga nagpuyo sa tubig ug ginakaon";
          // MEMBER: Janah Nicole M. Tayag
        agriDictionary[10]= "Bungkal: Proseso sa pag andam sa yuta";
        agriDictionary[11]= "Patubig: Paghatag ug tubig para ma buhi ang tanom";
        agriDictionary[12]= "Pestidsidyo: Kemikal na pang patay sa mga peste o insekto";
        agriDictionary[13]= "Peste: Mga insekto nga naga kaon o guba ug mga tanom";
        agriDictionary[14]= "Tubig: Gina dilig sa tanom para ma buhi ug mo tubo";

        // MEMBER: Kimberly L. Mas 
        agriDictionary[15]= "Kompost: Natural na abuno gikan sa basura o mga dahon";
        agriDictionary[16]= "Pananom: Proseso sa pag tanom ug mga gulay";
        agriDictionary[17]= "Pag-alaga: Pag atiman sa mga tanom ug hayop";
        agriDictionary[18]= "Kural: Harang para ma protektahan ang tanom";
        agriDictionary[19]= "Bulak: Parte sa tanom nga mahimo ug bunga";
    }

    // MEMBER: Jessa B.Torion
    // This method runs the program and allows user to search for a term
    public void runProgram() {
        Scanner sc = new Scanner(System.in);

        agriTerm1(); // load data

        System.out.print("Ibutang ang term: ");
        String input = sc.nextLine();

        boolean found = false;

        for (int i = 0; i < count; i++) {
            if (agriDictionary[i] != null) {
                String[] parts = agriDictionary[i].split(":");

                if (parts[0].equalsIgnoreCase(input)) {
                    System.out.println(parts[1]);
                    found = true;
                }
            }
        }

        if (!found) {
            System.out.println("Wala pa na dria nabutang bay.,. Salamat ha!");
        }
    }

    public static void main(String[] args) {
        AgriBisayaDictionary obj = new AgriBisayaDictionary();
        obj.runProgram();
    }
}
    }
